# Louisepizdon Configuration Example
# Copy this file to .env and fill in your values

TZ=Europe/Moscow

# APPLICATION_CONFIG должен содержать JSON конфигурацию в одну строку
# Пример (замените значения на свои):
APPLICATION_CONFIG={"telegram":{"botToken":"YOUR_BOT_TOKEN"},"redis":{"connectionString":"localhost:6379"},"database":{"connectionString":"Data Source=louisepizdon.db"},"artificial":{"openAIToken":"YOUR_OPENAI_API_KEY","chatModel":"gpt-4o","visionPromptBase64":""},"limits":{"dailyLimit":5,"monthlyLimit":30},"proxy":null}